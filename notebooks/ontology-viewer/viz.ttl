    viz:parentSize 32 .

viz:EdgeDefault a viz:StyleRule ;
    rdfs:label "Default edge style" ;
    viz:color "#555555" ;
    viz:width "1.5"^^xsd:float .

viz:Edge_RO_0002436 a viz:StyleRule ;
    viz:appliesToPredicate <http://purl.obolibrary.org/obo/RO_0002436> ;
    viz:color "#4682B488" ;
    viz:width "1.8"^^xsd:float .

viz:Edge_RO_0002449 a viz:StyleRule ;
    viz:appliesToPredicate <http://purl.obolibrary.org/obo/RO_0002449> ;
    viz:color "#00808099" ;
    viz:width "1.5"^^xsd:float .

viz:Edge_RO_0002450 a viz:StyleRule ;
    viz:appliesToPredicate <http://purl.obolibrary.org/obo/RO_0002450> ;
    viz:color "#00808099" ;
    viz:width "1.5"^^xsd:float .

viz:Edge_RO_0002606 a viz:StyleRule ;
    viz:appliesToPredicate <http://purl.obolibrary.org/obo/RO_0002606> ;
    viz:color "#4682B488" ;
    viz:width "1.8"^^xsd:float .

viz:Edge_develops a viz:StyleRule ;
    viz:appliesToPredicate vtx:develops ;
    viz:color "#FF634788" ;
    viz:dashed true ;
    viz:width "1.8"^^xsd:float .

viz:Edge_hasModality a viz:StyleRule ;
    viz:appliesToPredicate vtx:hasModality ;
    viz:color "#9370DB77" ;
    viz:dashed true ;
    viz:width "1.2"^^xsd:float .

viz:Edge_markets a viz:StyleRule ;
    viz:appliesToPredicate vtx:markets ;
    viz:color "#FFD70088" ;
    viz:width "2.0"^^xsd:float .

viz:Edge_subClassOf a viz:StyleRule ;
    viz:appliesToPredicate rdfs:subClassOf ;
    viz:color "#FFFFFF33" ;
    viz:dashed true ;
    viz:width "1.0"^^xsd:float .

