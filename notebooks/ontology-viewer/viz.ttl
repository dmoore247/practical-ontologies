@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix viz: <http://example.com/pharma/viz#> .
@prefix vtx: <http://example.com/pharma/domain#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

viz:ADMEStyle a viz:StyleRule ;
    rdfs:label "ADME" ;
    viz:appliesTo vtx:ADMEAssay ;
    viz:childSize 18 ;
    viz:color "#00CED1" ;
    viz:iconCode "\uF0EC" ;
    viz:iconFace "FontAwesome" ;
    viz:parentSize 34 .

viz:APPLStyle a viz:StyleRule ;
    rdfs:label "APPL" ;
