NCIT:C84397 · SERPINA1 gene target""" .

obo:OBI_0100051 a vtx:LabWorkflowEntity ;
    rdfs:label "Specimen" ;
    vtx:collectedAs <http://purl.allotrope.org/ontologies/result#AFR_0001118> ;
    rdfs:comment """OBI:0100051 — A material entity collected for investigation
Includes biological specimens, environmental samples""" .

obo:SCDO_1000106 a vtx:Disease ;
    rdfs:label "Sickle Cell Disease" ;
    rdfs:comment """SCDO:1000106 / MONDO:0011382 — HBB gene mutation
Sickle-shaped RBCs → pain crises, organ damage""" .

vtx:aat_def a vtx:Disease ;
    rdfs:label "AAT Deficiency" ;
    rdfs:comment """NCIT:C84397 / MONDO:0013282 — SERPINA1 mutations
α1-antitrypsin deficiency → liver & lung disease""" .

vtx:acute_pain a vtx:Disease ;
    rdfs:label "Acute Pain" ;
    rdfs:comment """MeSH:D059787 — Post-surgical & injury pain
NaV1.8-mediated nociceptive signaling""" .

vtx:cheminf a vtx:ComputationalMethod ;
    rdfs:label "Cheminformatics" ;
    vtx:optimizes vtx:sm ;
    vtx:predicts bao:BAO_0000009,
        bao:BAO_0002167 ;
    rdfs:comment """MeSH:D000080911 — Computational retrieval & analysis
of chemical data for drug discovery""" .

vtx:chronic_pain a vtx:Disease ;
    rdfs:label "Chronic Pain" ;
    rdfs:comment """MeSH:D059350 — Neuropathic & persistent pain
NaV1.8 / NaV1.7 targets""" .

vtx:hepatotox a vtx:ToxicityAssay ;
    rdfs:label "Hepatotoxicity Assay" ;
    vtx:biomarker_for vtx:aat_def ;
    vtx:monitors obo:NCIT_C84397 ;
