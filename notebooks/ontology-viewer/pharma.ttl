    obo:BFO_0000050 <http://purl.allotrope.org/ontologies/result#AFR_0002888> ;
    rdfs:comment """Individual well position in a microplate
Contains sample material for testing""" .

bao:BAO_0000009 a vtx:ADMEAssay ;
