obo:NCIT_C1962 a vtx:TreatmentModality ;
    rdfs:label "Gene Therapy" ;
    rdfs:comment """NCIT:C1962 — Nucleic acid-based therapeutic agents
Includes mRNA, siRNA, antisense""" .

obo:NCIT_C208191 a vtx:TreatmentModality ;
