        bao:BAO_0010139 .

bao:BAO_0000035 a vtx:DetectionMethod ;
    rdfs:label "Physical Detection Method" ;
    vtx:governs vtx:applicability ;
    rdfs:comment """BAO:0000035 — Physical method / technology used to
measure the readout of an assay.  Governs instrument
