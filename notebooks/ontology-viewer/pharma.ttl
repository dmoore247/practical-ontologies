    rdfs:label "has_assay_format" .

vtx:hasAssayStage a owl:ObjectProperty ;
    rdfs:label "has_assay_stage" .

vtx:hasBioassayType a owl:ObjectProperty ;
    rdfs:label "has_bioassay_type" .

vtx:hasComponent a owl:ObjectProperty ;
    rdfs:label "has_component" .

vtx:hasFormat a owl:ObjectProperty ;
    rdfs:label "has_format" .

vtx:hasModality a owl:ObjectProperty ;
    rdfs:label "modality" .

vtx:hasStage a owl:ObjectProperty ;
    rdfs:label "stage" .

vtx:hasType a owl:ObjectProperty ;
    rdfs:label "has_type" .

vtx:inputTo a owl:ObjectProperty ;
    rdfs:label "input_to" .

vtx:instanceOf a owl:ObjectProperty ;
    rdfs:label "instance_of" .

vtx:isFormulation a owl:ObjectProperty ;
    rdfs:label "is_formulation" .

vtx:loadedInto a owl:ObjectProperty ;
    rdfs:label "loaded_into" .

vtx:markets a owl:ObjectProperty ;
    rdfs:label "markets" .

vtx:ont_afo a vtx:OntologySource ;
    rdfs:label "AFO (Allotrope)" ;
    vtx:source <http://purl.allotrope.org/ontologies/result#AFR_0001118>,
        <http://purl.allotrope.org/ontologies/result#AFR_0001218>,
        <http://purl.allotrope.org/ontologies/result#AFR_0002888> ;
    rdfs:comment "Allotrope Foundation Ontology — Lab data & analytical workflows" .

vtx:ont_bao a vtx:OntologySource ;
    rdfs:label "BAO (BioAssay)" ;
    vtx:source bao:BAO_0000015,
        bao:BAO_0000035,
        bao:BAO_0000508,
        bao:BAO_0002094,
        bao:BAO_0002169 ;
    rdfs:comment "BioAssay Ontology — Screening assays, endpoints, HTS" .

vtx:ont_chebi a vtx:OntologySource ;
    rdfs:label "ChEBI" ;
    vtx:source obo:CHEBI_233446,
        obo:CHEBI_66902 ;
    rdfs:comment "Chemical Entities of Biological Interest — Molecular roles" .

vtx:ont_dron a vtx:OntologySource ;
    rdfs:label "DRON" ;
    vtx:source obo:DRON_00087770,
        obo:DRON_01061597 ;
    rdfs:comment "Drug Ontology — Drug products & formulations" .

vtx:ont_edam a vtx:OntologySource ;
    rdfs:label "EDAM" ;
    vtx:source <http://edamontology.org/topic_3332>,
        <http://edamontology.org/topic_3892> ;
    rdfs:comment "EDAM Ontology — Bioinformatics operations & topics" .

vtx:ont_mesh a vtx:OntologySource ;
    rdfs:label "MeSH" ;
    vtx:source <http://edamontology.org/topic_3307>,
        vtx:mol_dock ;
    rdfs:comment "Medical Subject Headings — Broad biomedical vocabulary" .

vtx:ont_mondo a vtx:OntologySource ;
    rdfs:label "MONDO" ;
    vtx:source obo:MONDO_0009061,
        obo:SCDO_1000106 ;
    rdfs:comment "Mondo Disease Ontology — Disease classification" .

vtx:ont_ncit a vtx:OntologySource ;
    rdfs:label "NCIT" ;
    vtx:source obo:NCIT_C180742,
        obo:NCIT_C616,
        vtx:cftr ;
    rdfs:comment "NCI Thesaurus — Drugs, diseases, genes, anatomy" .

vtx:ont_obi a vtx:OntologySource ;
    rdfs:label "OBI" ;
    vtx:source obo:OBI_0000070,
        obo:OBI_0100051 ;
    rdfs:comment "Ontology for Biomedical Investigations — Specimens, assays" .

vtx:preparedAs a owl:ObjectProperty ;
    rdfs:label "prepared_as" .

vtx:produces a owl:ObjectProperty ;
    rdfs:label "produces" .

vtx:quantifiedBy a owl:ObjectProperty ;
    rdfs:label "quantified_by" .

vtx:quantifies a owl:ObjectProperty ;
    rdfs:label "quantifies" .

vtx:screens a owl:ObjectProperty ;
    rdfs:label "screens" .

vtx:source a owl:ObjectProperty ;
    rdfs:label "source" .

vtx:supportsDetection a owl:ObjectProperty ;
    rdfs:label "supports_detection" .

vtx:testedIn a owl:ObjectProperty ;
    rdfs:label "tested_in" .

vtx:usedIn a owl:ObjectProperty ;
    rdfs:label "used_in" .

<http://edamontology.org/topic_0176> a vtx:ComputationalMethod ;
    rdfs:label "Molecular Dynamics" ;
    vtx:simulates vtx:cftr ;
    rdfs:comment """EDAM:topic_0176 — Protein conformation simulation
Force-field based time evolution""" .

<http://edamontology.org/topic_3332> a vtx:ComputationalMethod ;
    rdfs:label "Computational Chemistry" ;
    vtx:subfield vtx:cheminf,
        vtx:mol_dock ;
    rdfs:comment """EDAM:topic_3332 / MeSH:D000080486 / NCIT:C18470
Molecular property calculation & simulation""" .

obo:MONDO_0005147 a vtx:Disease ;
    rdfs:label "Type 1 Diabetes" ;
    rdfs:comment """MONDO:0005147 — Autoimmune destruction of β-cells
Insulin-dependent diabetes mellitus""" .

obo:MONDO_0005342 a vtx:Disease ;
    rdfs:label "IgA Nephropathy" ;
    rdfs:comment """MONDO:0005342 / MeSH:D005922 — IgA deposition in glomeruli
Most common primary glomerulonephritis worldwide""" .

obo:MONDO_0016668 a vtx:Disease ;
    rdfs:label "β-Thalassemia" ;
    rdfs:comment """MONDO:0016668 — Reduced β-globin chain production
Severe anemia requiring transfusions""" .

obo:NCIT_C134270 a vtx:ReadoutContent ;
    rdfs:label "Potency Assay" ;
    vtx:release_test obo:NCIT_C169042,
        obo:NCIT_C181923 ;
    vtx:required_for vtx:st_biologic,
        vtx:st_cell_therapy ;
    rdfs:comment """NCIT:C134270 — Determines strength of a material
by measuring ability to produce a specific response.
Critical for biologics & cell therapy release testing:
Casgevy potency, VX-880 islet function.""" .

obo:NCIT_C172787 a vtx:TreatmentModality ;
    rdfs:label "mRNA Therapeutic" ;
    rdfs:comment """NCIT:C172787 mRNA platform
In vitro transcribed mRNA encoding therapeutic proteins""" .

obo:NCIT_C175342 a vtx:TreatmentModality ;
    rdfs:label "CRISPR-Cas9 Gene Editing" ;
    rdfs:comment """NCIT:C175342 — Precision genome editing
Ex vivo editing of HSPCs at BCL11A enhancer""" .

obo:OBI_0000443 a vtx:LabWorkflowEntity ;
    rdfs:label "Analyte Assay" ;
    rdfs:comment """OBI:0000443 — Assay measuring specific analyte
Concentration or activity""" .

obo:OBI_0001479 a vtx:SampleType ;
    rdfs:label "Tissue / Organ Sample" ;
    vtx:compatible bao:BAO_0000055,
        bao:BAO_0000452 ;
    <http://example.com/pharma/domain#✓> bao:BAO_0000218 ;
    rdfs:comment """OBI:0001479 — Specimen from organism
Eligible for: histopathology, biomarker,
organ-specific tox, tissue distribution""" .

obo:OBI_0400076 a vtx:LabWorkflowEntity ;
    rdfs:label "Multi-well Plate" ;
    rdfs:comment """OBI:0400076 — multi-well plate
General class for plates with multiple wells""" ;
    rdfs:subClassOf bao:BAO_0000508 .

vtx:ApplicabilityMatrix a owl:Class ;
    rdfs:label "APPL" ;
    rdfs:subClassOf vtx:DomainEntity .

vtx:PharmaceuticalCompany a owl:Class ;
    rdfs:label "HUB" ;
    rdfs:subClassOf vtx:DomainEntity .

vtx:active_ingr a vtx:LabWorkflowEntity ;
    rdfs:label "Active Ingredient" ;
    rdfs:comment """Pharmacologically active substance
in a drug formulation (API)""" .

vtx:bcl11a a vtx:MolecularTarget ;
    rdfs:label "BCL11A Enhancer" ;
    rdfs:comment """Erythroid-specific enhancer of BCL11A gene
CRISPR target to reactivate fetal hemoglobin (HbF)""" .

vtx:brain_penet a vtx:ADMEAssay ;
    rdfs:label "Brain Penetration" ;
    rdfs:comment """CNS penetration assessment
Kp,uu brain-to-plasma ratio""" .

vtx:chromo_ab a vtx:ToxicityAssay ;
    rdfs:label "Chromosomal Aberration" ;
    rdfs:comment """In vitro chromosomal aberration assay
Detects structural/numerical chromosome changes
Alternative to micronucleus for ICH S2(R1)""" .

vtx:comet a vtx:ToxicityAssay ;
    rdfs:label "Comet Assay (SCGE)" ;
    rdfs:comment """Single Cell Gel Electrophoresis
Detects DNA strand breaks at single-cell level
In vivo follow-up for positive in vitro genotox""" .

vtx:component a vtx:LabWorkflowEntity ;
    rdfs:label "Component" ;
    rdfs:comment """Individual ingredient or constituent
of a formulation or material""" ;
    rdfs:subClassOf obo:NCIT_C616,
        vtx:active_ingr,
        vtx:excipient .

vtx:distrib a vtx:ADMEAssay ;
    rdfs:label "Drug Distribution" ;
    rdfs:comment """Tissue distribution & protein binding
Determines free drug concentration at target""" ;
    rdfs:subClassOf vtx:brain_penet,
        bao:BAO_0002532,
        bao:BAO_0010135 .

vtx:drug_disc a vtx:ComputationalMethod ;
    rdfs:label "Drug Discovery" ;
    vtx:supports obo:NCIT_C180742 ;
    vtx:uses bao:BAO_0002094 ;
    rdfs:comment """Computational drug discovery pipeline
Target ID → Hit finding → Lead optimization""" .

vtx:excipient a vtx:LabWorkflowEntity ;
    rdfs:label "Excipient" ;
    rdfs:comment """Inactive ingredient in formulation
Binders, fillers, coatings, solvents""" .

vtx:form_desc a vtx:LabWorkflowEntity ;
    rdfs:label "Formulation Description" ;
    rdfs:comment """Data object describing ingredient composition
Includes excipients, active ingredients, ratios""" .

vtx:hemolysis a vtx:ToxicityAssay ;
    rdfs:label "Hemolysis Assay" ;
    vtx:screens vtx:lnp,
        vtx:mrna_cf ;
    rdfs:comment """Measures red blood cell lysis caused by compounds
Critical safety screen for IV-administered drugs & LNP formulations""" .

vtx:ld50 a vtx:ToxicityAssay ;
    rdfs:label "LD50" ;
    rdfs:comment """Lethal Dose 50 — dose causing 50% mortality
In vivo acute toxicity measure
Increasingly replaced by alternative methods""" .

vtx:lipid_np a vtx:LabWorkflowEntity ;
    rdfs:label "Lipid Nanoparticle" ;
    vtx:deliveryFor vtx:mrna_cf ;
    vtx:instanceOf vtx:lnp ;
    vtx:isFormulation <http://purl.allotrope.org/ontologies/result#AFR_0001218> ;
    rdfs:comment """Lipid-based nanocarrier for nucleic acid delivery
Formulation: ionizable lipid + PEG-lipid + cholesterol + helper lipid""" .

vtx:mm_sim a vtx:ComputationalMethod ;
    rdfs:label "Molecular Mechanics" ;
    rdfs:comment """ECO:0006138 — Energy prediction from conformation
Force-field based approaches""" .

vtx:mtd a vtx:ToxicityAssay ;
    rdfs:label "Maximum Tolerated Dose (MTD)" ;
    rdfs:comment """Dose-finding study to identify highest tolerable dose
Key input for therapeutic index calculation""" .

vtx:pampa a vtx:ADMEAssay ;
    rdfs:label "PAMPA" ;
    rdfs:comment """Parallel Artificial Membrane Permeability Assay
Artificial lipid membrane — no active transport
Fastest passive permeability screen""" .

vtx:phototox a vtx:ToxicityAssay ;
    rdfs:label "Phototoxicity Assay" ;
    vtx:screens obo:CHEBI_233446,
        vtx:trikafta ;
    rdfs:comment """3T3 NRU phototoxicity test (ICH S10)
Measures UV/vis-induced cytotoxicity
Required for compounds absorbing 290–700 nm""" .

vtx:qmmm a vtx:ComputationalMethod ;
    rdfs:label "QM/MM Simulation" ;
    rdfs:comment """ECO:0006135 — Quantum mechanics + molecular mechanics
High-accuracy active site modeling""" .

vtx:sample_type_hub a vtx:SampleType ;
    rdfs:label "Sample Type (N types)" ;
    vtx:constrained_by vtx:applicability ;
    vtx:hasType obo:OBI_0001479,
        vtx:st_biologic,
        vtx:st_cell_line,
        vtx:st_cell_therapy,
        vtx:st_compound,
        vtx:st_formulation,
        vtx:st_lnp_form,
        vtx:st_nucleic,
        bao:BAO_0020004 ;
    rdfs:comment """Categorization of material submitted for testing
Each sample type constrains which tests are applicable""" .

vtx:st_cell_line a vtx:SampleType ;
    rdfs:label "Cell Line / Primary Cells" ;
    vtx:compatible bao:BAO_0000005,
        bao:BAO_0000045,
        bao:BAO_0000046,
        bao:BAO_0000163,
        bao:BAO_0000452 ;
    <http://example.com/pharma/domain#✓> bao:BAO_0000219 ;
    rdfs:comment """Living cells used as the assay system
Eligible for: cell-based format assays only
Viability, proliferation, reporter, phenotypic""" .

vtx:st_compound a vtx:SampleType ;
    rdfs:label "Compound / Small Molecule" ;
    vtx:compatible bao:BAO_0000045,
        bao:BAO_0000046,
        bao:BAO_0000049,
        bao:BAO_0000055,
        bao:BAO_0000427,
        bao:BAO_0000657 ;
    vtx:sample_for vtx:sm ;
    <http://example.com/pharma/domain#✓> bao:BAO_0000100,
        bao:BAO_0000218,
        bao:BAO_0000219,
        bao:BAO_0000357,
        bao:BAO_0000366 ;
    rdfs:comment """Pure chemical entity (API or lead compound)
Eligible for: biochemical, cell-based, physicochemical,
ADME, tox, in vivo PK assays""" .

vtx:st_formulation a vtx:SampleType ;
    rdfs:label "Drug Formulation" ;
    vtx:refines <http://purl.allotrope.org/ontologies/result#AFR_0001218> ;
    <http://example.com/pharma/domain#✓> bao:BAO_0000100,
        bao:BAO_0000218 ;
    rdfs:comment """Finished or intermediate drug product
Eligible for: dissolution, stability, content uniformity,
bioequivalence, formulation-specific assays""" .

vtx:st_lnp_form a vtx:SampleType ;
    rdfs:label "LNP Formulation" ;
    vtx:compatible bao:BAO_0000049,
        bao:BAO_0000055,
        bao:BAO_0000452 ;
    vtx:sample_for vtx:mrna_cf ;
    <http://example.com/pharma/domain#✓> bao:BAO_0000100,
        bao:BAO_0000218,
        bao:BAO_0000219 ;
    rdfs:comment """Lipid nanoparticle drug product
Eligible for: particle size (DLS), zeta potential,
encapsulation %, hemolysis, tissue distribution
NOT eligible for standard small-molecule ADME""" .

vtx:symdeko a vtx:ApprovedDrug ;
    rdfs:label "Symdeko (tezacaftor/ ivacaftor)" ;
    obo:RO_0002606 obo:MONDO_0009061 ;
    vtx:containsAgent obo:CHEBI_66902,
        vtx:cftr_cor ;
    vtx:hasModality vtx:sm ;
    rdfs:comment """MeSH:C000654124 — Next-gen corrector + potentiator · Approved 2018
CHEBI:234517""" .

vtx:vx_548_crps a vtx:PipelineTherapy ;
    rdfs:label "VX-548 (chronic pain)" ;
    obo:RO_0002436 vtx:chronic_pain ;
    rdfs:comment """Suzetrigine extension into chronic pain indications
Neuropathic pain, CRPS studies""" .

vtx:vx_pain2 a vtx:PipelineTherapy ;
    rdfs:label "Next-gen NaV1.8 / NaV1.7" ;
    obo:RO_0002436 vtx:acute_pain,
        vtx:chronic_pain ;
    obo:RO_0002449 obo:NCIT_C114811,
        vtx:nav18 ;
    rdfs:comment """Follow-on pain programs targeting voltage-gated sodium channels
SCN10A (NaV1.8) · SCN9A (NaV1.7)""" .

bao:BAO_0000001 a vtx:DetectionMethod ;
    rdfs:label "FRET" ;
    vtx:readout_for bao:BAO_0010123 ;
    rdfs:comment """BAO:0000001 — Fluorescence Resonance Energy Transfer
Donor→Acceptor energy transfer within <10nm
Subclasses: TR-FRET (HTRF/LANCE), SNAP-tag, PerkinElmer""" .

bao:BAO_0000003 a vtx:DetectionMethod ;
    rdfs:label "Fluorescence Polarization (FP)" ;
    vtx:readout_for bao:BAO_0010159 ;
    rdfs:comment """BAO:0000003 — Rotational motion-based binding assay
Small fluorescent tracer binds large target → high polarization
Widely used for kinase, protease & PPI assays""" .

bao:BAO_0000006 a vtx:ToxicityAssay ;
    rdfs:label "% Cytotoxicity" ;
    rdfs:comment """BAO:0000006 — Percent cytotoxicity endpoint
Normalized to positive/negative controls
BAO:0000588 = 50% cytotoxicity threshold""" .

bao:BAO_0000019 a vtx:TestType ;
    rdfs:label "Assay Format" ;
    vtx:governs vtx:applicability ;
    vtx:hasFormat bao:BAO_0000100,
        bao:BAO_0000218,
        bao:BAO_0000219,
        bao:BAO_0000357,
        bao:BAO_0000366 ;
    rdfs:comment """BAO:0000019 — Conceptualization of assays based on
biological/chemical features of experimental system""" .

bao:BAO_0000029 a vtx:TestType ;
    rdfs:label "Screening Campaign Stage" ;
    vtx:governs vtx:applicability ;
    vtx:has_stage bao:BAO_0000030,
        bao:BAO_0000031,
        bao:BAO_0000032,
        bao:BAO_0000803,
        bao:BAO_0010025 ;
    rdfs:comment """BAO:0000029 — Purpose & order of assay in drug discovery
Determines which assays are run at each stage
Primary → Confirmatory → Secondary → Preclinical""" .

bao:BAO_0000051 a vtx:DetectionMethod ;
    rdfs:label "Chemiluminescence" ;
    vtx:readout_for vtx:hepatotox ;
    rdfs:comment """BAO:0000051 — Light from synthetic oxidation reactions
ELISA-CL, Western blot-CL, high-sensitivity immunoassays""" .

bao:BAO_0000058 a vtx:DetectionMethod ;
    rdfs:label "Thermal Shift (DSF)" ;
    vtx:screens vtx:cftr ;
    rdfs:comment """BAO:0000058 — Differential Scanning Fluorimetry
Protein unfolding temperature shift upon ligand binding
Hit validation & target engagement for CFTR modulators""" .

bao:BAO_0000071 a vtx:DetectionMethod ;
    rdfs:label "Transmittance" ;
    rdfs:comment """BAO:0000071 — Ratio of transmitted to incident light (T = I/I₀)
Turbidity, particle sizing, dissolution monitoring""" .

bao:BAO_0000130 a vtx:DetectionMethod ;
    rdfs:label "AlphaScreen" ;
    vtx:readout_for bao:BAO_0000015 ;
    rdfs:comment """BAO:0000130 — Amplified Luminescent Proximity Homogeneous Assay
Donor/acceptor bead proximity → singlet oxygen cascade → 520-620nm
PPI, kinase, epigenetics — no-wash, miniaturizable to 1536""" .

bao:BAO_0000136 a vtx:ReadoutContent ;
    rdfs:label "Single Repetition" ;
    vtx:typical_for bao:BAO_0000031 ;
    rdfs:comment """BAO:0000136 — One measurement per compound per conc.
Fastest throughput, used in primary HTS.
Z' > 0.5 required for reliable hit calling.""" .

bao:BAO_0000137 a vtx:ReadoutContent ;
    rdfs:label "Multiple Repetitions" ;
    vtx:typical_for bao:BAO_0000030 ;
    rdfs:comment """BAO:0000137 — Replicate measurements (n=2–4 typical).
Confirmatory & secondary screens.
Enables statistical significance & error estimation.""" .

bao:BAO_0000160 a vtx:DetectionMethod ;
    rdfs:label "NMR" ;
    vtx:informs <http://edamontology.org/topic_0082> ;
    rdfs:comment """BAO:0000160 — Nuclear Magnetic Resonance
Protein-ligand binding by chemical shift perturbation
Fragment screening, structure determination""" .

bao:BAO_0000161 a vtx:DetectionMethod ;
    rdfs:label "Circular Dichroism" ;
    vtx:characterizes vtx:st_biologic,
        vtx:st_nucleic ;
    rdfs:comment """BAO:0000161 — Chiral interaction with polarized light
Protein secondary structure, conformational stability
Biologic & mRNA product characterization""" .

bao:BAO_0000184 a vtx:ReadoutContent ;
    rdfs:label "Image-Based Readout (HCS)" ;
    vtx:analyzed_by <http://edamontology.org/topic_3307> ;
    vtx:readout_via bao:BAO_0002526 ;
    vtx:uses_detection bao:BAO_0000452 ;
    rdfs:comment """BAO:0000184 — High Content Screening.  Automated imaging
+ analysis: 10s–100s of parameters per cell.
Morphology, translocation, phenotypic profiling.
Cell Painting for CFTR correctors & toxicity.""" .

bao:BAO_0000187 a vtx:ToxicityAssay ;
    rdfs:label "CC50" ;
    rdfs:comment """BAO:0000187 — 50% cytotoxic concentration
Effective concentration producing 50% max cell death
Key selectivity metric: CC50 / IC50 = therapeutic index""" ;
    rdfs:subClassOf bao:BAO_0000179 .

bao:BAO_0000202 a vtx:ToxicityAssay ;
    rdfs:label "% Cell Viability" ;
    rdfs:comment """BAO:0000202 — Percent cell viability endpoint
100 − % cytotoxicity
CellTiter-Glo, alamarBlue, MTT readouts""" .

bao:BAO_0000404 a vtx:DetectionMethod ;
    rdfs:label "X-ray Crystallography" ;
    vtx:informs <http://edamontology.org/topic_0082> ;
    vtx:validates vtx:mol_dock ;
    rdfs:comment """BAO:0000404 — Protein-compound co-crystal diffraction
Definitive binding mode & structure-based drug design
Essential for CFTR modulator optimization""" .

bao:BAO_0000409 a vtx:ReadoutContent ;
    rdfs:label "Measurement Type" ;
    rdfs:comment """BAO:0000409 — Temporal & functional nature of measurement.
Endpoint (static snapshot) vs Kinetic (time-course)
vs Concentration-Response (dose-response curve)
vs Potency (strength determination).""" ;
    rdfs:subClassOf obo:NCIT_C134270,
        bao:BAO_0000410,
        bao:BAO_0000411,
        bao:BAO_0010258 .

bao:BAO_0000410 a vtx:ReadoutContent ;
    rdfs:label "Endpoint Assay" ;
    vtx:typical_method bao:BAO_0000050,
        bao:BAO_0000070 ;
    rdfs:comment """BAO:0000410 — Static response at a fixed time point.
No time dimension in reported result.
Cell viability at 72h, % inhibition at 24h.
Most common HTS measurement type.""" .

bao:BAO_0000411 a vtx:ReadoutContent ;
    rdfs:label "Kinetic Assay" ;
    vtx:typical_method bao:BAO_0000057,
        bao:BAO_0000163 ;
    rdfs:comment """BAO:0000411 — Time-course measurement; result has
temporal component: rate constant, Km, Vmax.
Enzyme kinetics, real-time calcium flux (FLIPR),
SPR binding kinetics (ka, kd).""" .

bao:BAO_0000428 a vtx:DetectionMethod ;
    rdfs:label "ITC (Isothermal Calorimetry)" ;
    rdfs:comment """BAO:0000428 — Direct thermodynamic binding measurement
Ka, ΔH, ΔS, stoichiometry — label-free, in-solution""" .

bao:BAO_0000456 a vtx:DetectionMethod ;
    rdfs:label "QCM" ;
    rdfs:comment """BAO:0000456 — Quartz Crystal Microbalance
Piezoelectric frequency shift on mass deposition
Cell adhesion, receptor-ligand, polymer films""" .

bao:BAO_0000513 a vtx:LabWorkflowEntity ;
    rdfs:label "96-Well Plate" ;
    rdfs:comment "BAO:0000513 — Suitable for low-throughput assay" .

bao:BAO_0000515 a vtx:LabWorkflowEntity ;
    rdfs:label "384-Well Plate" ;
    rdfs:comment "BAO:0000515 — Suitable for HTS assay" .

bao:BAO_0000516 a vtx:LabWorkflowEntity ;
    rdfs:label "1536-Well Plate" ;
    rdfs:comment "BAO:0000516 — Highly miniaturized, few µL volumes" .

bao:BAO_0000532 a vtx:ReadoutContent ;
    rdfs:label "Measurement Throughput" ;
    vtx:has_axis bao:BAO_0002177,
        bao:BAO_0002178 ;
    rdfs:comment """BAO:0000532 — Describes the quality/quantity of
measurements per sample: concentration design
(single vs dose-response) × replication design
(single vs multiple replicates).""" .

bao:BAO_0000534 a vtx:ReadoutContent ;
    rdfs:label "Single Readout" ;
    vtx:typical_readout bao:BAO_0000050,
        bao:BAO_0000070,
        bao:BAO_0000363 ;
    rdfs:comment """BAO:0000534 — Typical HTS assay: plate reader generates
1–2 readout values per well.  Simplest data structure,
highest throughput.  ~80% of primary screens.""" .

bao:BAO_0000535 a vtx:ReadoutContent ;
    rdfs:label "Multiple Concentration" ;
    vtx:typical_for bao:BAO_0000030,
        bao:BAO_0000032 ;
    rdfs:comment """BAO:0000535 — Dose-response / concentration-response.
qHTS (quantitative HTS): 7–16 point curves.
Generates IC50, EC50, Hill slope, Emax.""" .

bao:BAO_0000536 a vtx:ReadoutContent ;
    rdfs:label "Single Concentration" ;
    vtx:typical_for bao:BAO_0000031 ;
    rdfs:comment """BAO:0000536 — One concentration per compound.
Typical for primary HTS: binary active/inactive call.
~1M compounds × 1 conc × 1 rep = maximum throughput.""" .

bao:BAO_0000564 a vtx:ReadoutContent ;
    rdfs:label "Multiplexed Readout" ;
    vtx:readout_via bao:BAO_0000005,
        bao:BAO_0000046 ;
    rdfs:comment """BAO:0000564 — Multiple targets measured simultaneously
from one well using differentially-labeled probes.
Luminex bead arrays, Meso Scale Discovery (MSD).
Cytokine panels, PK multiplexing.""" .

bao:BAO_0000576 a vtx:LabWorkflowEntity ;
    rdfs:label "24-Well Plate" ;
    rdfs:comment "BAO:0000576 — Suitable for low-throughput assay" .

bao:BAO_0000803 a vtx:TestType ;
    rdfs:label "Counter Screen" ;
    vtx:parallel_to bao:BAO_0000032 ;
    rdfs:comment """BAO:0000803 — Eliminates artifacts & false positives
Cytotox counter-screen, fluorescence interference
Runs parallel to secondary stage""" .

bao:BAO_0002067 a vtx:ReadoutContent ;
    rdfs:label "Readout Type" ;
    rdfs:comment """BAO:0002067 — Nature of the reported value from an assay.
Raw instrument output vs derived calculation vs
multi-dimensional profile (spectrum, image features).""" ;
    rdfs:subClassOf bao:BAO_0002068,
        bao:BAO_0002069,
        bao:BAO_0002070 .

bao:BAO_0002068 a vtx:ReadoutContent ;
    rdfs:label "Calculated Value" ;
    vtx:derives bao:BAO_0000179 ;
    rdfs:comment """BAO:0002068 — Derived from raw measurements.
% Inhibition, % Activity, Z-score,
IC50, EC50, Ki, Kd — the interpretable result.""" .

bao:BAO_0002069 a vtx:ReadoutContent ;
    rdfs:label "Measured Profile" ;
    vtx:inputTo vtx:cheminf ;
    vtx:output_of bao:BAO_0000055 ;
    rdfs:comment """BAO:0002069 — Multi-dimensional data output.
Mass spectra, chromatograms, image feature vectors,
gene expression signatures, Cell Painting profiles.""" .

bao:BAO_0002070 a vtx:ReadoutContent ;
    rdfs:label "Measured Value" ;
    vtx:produces vtx:result_datum ;
    rdfs:comment """BAO:0002070 — Raw instrument output value.
Fluorescence intensity (RFU), luminescence (RLU),
absorbance (OD), counts per minute (CPM).
Input to normalization & curve-fitting.""" .

bao:BAO_0002177 a vtx:ReadoutContent ;
    rdfs:label "Concentration Throughput" ;
    rdfs:comment """BAO:0002177 — Number of concentrations tested per compound.
Determines whether assay yields binary hit/miss
or full dose-response curve (IC50/EC50).""" ;
    rdfs:subClassOf bao:BAO_0000535,
        bao:BAO_0000536 .

bao:BAO_0002178 a vtx:ReadoutContent ;
    rdfs:label "Repetition Throughput" ;
    rdfs:comment """BAO:0002178 — Number of replicate measurements per condition.
Governs statistical power and assay quality (Z').""" ;
    rdfs:subClassOf bao:BAO_0000136,
        bao:BAO_0000137 .

bao:BAO_0002188 a vtx:ADMEAssay ;
    rdfs:label "Drug-Drug Interaction" ;
    rdfs:comment """BAO:0002188 — Drug interaction assay
CYP/transporter-mediated DDI potential""" ;
    rdfs:subClassOf bao:BAO_0003008,
        bao:BAO_0010149,
        bao:BAO_0010159,
        bao:BAO_0010169 .

bao:BAO_0002189 a vtx:ADMEAssay ;
    rdfs:label "Toxicity Assay" ;
    vtx:classified_as bao:BAO_0013018 ;
    vtx:reactive_metabolite bao:BAO_0010245 ;
    rdfs:comment """BAO:0002189 — General toxicity assessment
In vitro cytotoxicity, genotoxicity (Ames)""" ;
    rdfs:subClassOf vtx:cardiotox,
        vtx:hepatotox,
        vtx:phototox,
        bao:BAO_0000008,
        bao:BAO_0002167,
        bao:BAO_0002993,
        bao:BAO_0013053 .

bao:BAO_0002525 a vtx:DetectionMethod ;
    rdfs:label "Tomography" ;
    vtx:readout_for vtx:invivo_tox,
        bao:BAO_0002532 ;
    rdfs:comment """BAO:0002525 — Cross-sectional imaging (µCT, PET, SPECT)
In vivo imaging for biodistribution & efficacy studies""" .

bao:BAO_0002529 a vtx:DetectionMethod ;
    rdfs:label "Atomic Absorption Spectrophotometry" ;
    rdfs:comment """BAO:0002529 — Elemental analysis via atomic vapor absorption
Metal contamination testing, elemental impurities (ICH Q3D)""" .

bao:BAO_0002533 a vtx:ADMEAssay ;
    rdfs:label "Safety Pharmacology" ;
    rdfs:comment """BAO:0002533 — Safety pharmacology assay panel
Cardiac, respiratory, CNS safety""" ;
    rdfs:subClassOf vtx:cardiotox,
        bao:BAO_0002189,
        bao:BAO_0013041 .

bao:BAO_0002969 a vtx:ReadoutContent ;
    rdfs:label "Readout Parameter" ;
    vtx:specifies bao:BAO_0000040 ;
    rdfs:comment """BAO:0002969 — The specific observable being quantified.
Intensity, count, morphology, translocation, area,
texture — parameters extracted from HCS image analysis
or plate-reader raw signals.""" .

bao:BAO_0003008 a vtx:ADMEAssay ;
    rdfs:label "Transporter Assay" ;
    rdfs:comment """BAO:0003008 — Membrane transporter assessment
P-gp, BCRP, OATP, OAT, OCT substrates""" ;
    rdfs:subClassOf bao:BAO_0010189,
        bao:BAO_0010205 .

bao:BAO_0010006 a vtx:ADMEAssay ;
    rdfs:label "Microsomal Stability" ;
    rdfs:comment """BAO:0010006 — Liver microsome incubation
CYP-mediated Phase I metabolism
% recovery or t½ across species""" .

bao:BAO_0010082 a vtx:ADMEAssay ;
    rdfs:label "Drug Absorption" ;
    rdfs:comment """BAO:0010082 — Drug absorption assay
Intestinal uptake & oral bioavailability""" ;
    rdfs:subClassOf bao:BAO_0010010,
        bao:BAO_0010083 .

bao:BAO_0010083 a vtx:ADMEAssay ;
    rdfs:label "Permeability Assay" ;
    rdfs:comment """BAO:0010083 — Measures compound passage
across biological membrane barriers""" ;
    rdfs:subClassOf vtx:pampa,
        bao:BAO_0010008,
        bao:BAO_0010089 .

bao:BAO_0010089 a vtx:ADMEAssay ;
    rdfs:label "MDCKII Permeability" ;
    rdfs:comment """BAO:0010089 — Madin-Darby canine kidney II
Rapid polarized barrier for Papp measurement
High-throughput passive permeability screen""" .

bao:BAO_0010090 a vtx:ADMEAssay ;
    rdfs:label "Drug Metabolism" ;
    rdfs:comment """BAO:0010090 — In vitro metabolic clearance
and metabolite characterization""" ;
    rdfs:subClassOf bao:BAO_0010091,
        bao:BAO_0010095,
        bao:BAO_0010123 .

bao:BAO_0010100 a vtx:ADMEAssay ;
    rdfs:label "Hepatocyte Stability" ;
    rdfs:comment """BAO:0010100 — Whole-cell metabolic clearance
Phase I + Phase II metabolism
More physiologically relevant than microsomes""" ;
    rdfs:subClassOf bao:BAO_0010101 .

bao:BAO_0010101 a vtx:ADMEAssay ;
    rdfs:label "Hepatocyte Low-Clearance" ;
    rdfs:comment """BAO:0010101 — Relay assay for slowly-cleared compounds
Extended incubation with cell replenishment""" .

bao:BAO_0010139 a vtx:ADMEAssay ;
    rdfs:label "Drug Excretion" ;
    rdfs:comment """BAO:0010139 — Drug excretion assay
Elimination routes: biliary, renal, fecal""" ;
    rdfs:subClassOf bao:BAO_0010140 .

bao:BAO_0010140 a vtx:ADMEAssay ;
    rdfs:label "Mass Balance Assay" ;
    rdfs:comment """BAO:0010140 — Quantifies total recovery
across all excretion routes""" ;
    rdfs:subClassOf bao:BAO_0010141,
        bao:BAO_0010143 .

bao:BAO_0010141 a vtx:ADMEAssay ;
    rdfs:label "Biliary Excretion" ;
    rdfs:comment """BAO:0010141 — Hepatobiliary elimination
Sandwich-cultured hepatocyte BEI assay""" .

bao:BAO_0010143 a vtx:ADMEAssay ;
    rdfs:label "Renal Excretion" ;
    rdfs:comment """BAO:0010143 — Kidney elimination pathway
Glomerular filtration & tubular secretion""" .

bao:BAO_0010149 a vtx:ADMEAssay ;
    rdfs:label "CYP Induction" ;
    rdfs:comment """BAO:0010149 — Enzyme induction via nuclear receptors
PXR/CAR-mediated CYP3A4/1A2/2B6 upregulation""" .

bao:BAO_0010169 a vtx:ADMEAssay ;
    rdfs:label "CYP Time-Dep Inhibition" ;
    rdfs:comment """BAO:0010169 — Mechanism-based inactivation
IC50 shift & kinact/KI determination""" .

bao:BAO_0010189 a vtx:ADMEAssay ;
    rdfs:label "Efflux Transporter Inhibition" ;
    rdfs:comment """BAO:0010189 — P-gp/BCRP/MRP2 inhibition
DDI victim assessment""" .

bao:BAO_0010205 a vtx:ADMEAssay ;
    rdfs:label "Efflux Transporter Substrate" ;
    rdfs:comment """BAO:0010205 — P-gp/BCRP substrate assessment
Bidirectional assay with efflux ratio""" .

bao:BAO_0010243 a vtx:ToxicityAssay ;
    rdfs:label "Chemical Stability" ;
    rdfs:comment """BAO:0010243 — Chemical stability assay
pH, light, oxidative stability of compound
Informs formulation and storage conditions""" .

bao:BAO_0010246 a vtx:ADMEAssay ;
    rdfs:label "Thermodynamic Solubility" ;
    rdfs:comment """BAO:0010246 — Equilibrium solubility of crystalline
material in aqueous buffer""" .

bao:BAO_0010258 a vtx:ReadoutContent ;
    rdfs:label "Concentration- Response Assay" ;
    vtx:generates bao:BAO_0010008,
        bao:BAO_0010159,
        bao:BAO_0013041 ;
    rdfs:comment """BAO:0010258 — Dose-response curve measurement.
Generates IC50, EC50, Hill coefficient, Emax.
Standard for confirmatory & secondary screens.
Required for all ADME dose-finding studies.""" .

bao:BAO_0010264 a vtx:DetectionMethod ;
    rdfs:label "Biosensor Method" ;
    vtx:monitors obo:NCIT_C181923 ;
    rdfs:comment """BAO:0010264 — Biological recognition + physical transducer
Enzyme electrode, aptamer sensor, cell-based biosensor
Emerging for continuous glucose monitoring (T1D/VX-880)""" .

bao:BAO_0013018 a vtx:ToxicityAssay ;
    rdfs:label "Toxicology (BAO Type)" ;
    rdfs:comment """BAO:0013018 — Investigation of adverse effects
of chemical substances on living organisms
Encompasses all in vivo & in vitro tox studies""" ;
    rdfs:subClassOf vtx:invivo_tox .

bao:BAO_0020004 a vtx:SampleType ;
    rdfs:label "Blood / Plasma / Serum" ;
    vtx:compatible bao:BAO_0000049,
        bao:BAO_0000055,
        bao:BAO_0000657 ;
    <http://example.com/pharma/domain#✓> bao:BAO_0000366 ;
    rdfs:comment """BAO:0020004 serum format · OBI blood specimen
Eligible for: PK/bioanalytical, PPB, biomarker,
hematology (NOT cell-based HTS)""" .

bao:BAO_0050013 a vtx:DetectionMethod ;
    rdfs:label "Proximity-Based Method" ;
    vtx:measures_engagement vtx:cftr_cor ;
    rdfs:comment """BAO:0050013 — Measures spatial proximity of tagged molecules
NanoBRET, NanoBiT, PLA — protein-protein interaction
Target engagement in live cells for CFTR correctors""" .

<https://www.genenames.org/data/gene-symbol-report/#!/hgnc_id/HGNC:8941> a vtx:MolecularTarget ;
    rdfs:label "SERPINA1 (AAT gene)" ;
    rdfs:comment """HGNC:8941 / NCIT:C105011 — Serine protease inhibitor
Mutations cause AAT deficiency (Z-allele most common)""" .

<http://edamontology.org/topic_3307> a vtx:ComputationalMethod ;
