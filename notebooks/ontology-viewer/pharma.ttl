Key for AAT deficiency program (liver disease)""" .

vtx:invivo_tox a vtx:ToxicityAssay ;
    rdfs:label "In Vivo Toxicology" ;
    vtx:determines vtx:mtd ;
    bao:BAO_0000208 vtx:ld50 ;
