@prefix bao: <http://www.bioassayontology.org/bao#> .
@prefix ns1: <http://example.com/pharma/domain#Toxicity/> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix vtx: <http://example.com/pharma/domain#> .

<http://purl.allotrope.org/ontologies/result#AFR_0002231> a vtx:LabWorkflowEntity ;
    rdfs:label "Plate Well Count" ;
    vtx:quantifies <http://purl.allotrope.org/ontologies/result#AFR_0002888> ;
    rdfs:comment "AFO:AFR_0002231 — Number of well positions on a plate" .

<http://purl.allotrope.org/ontologies/result#AFR_0002232> a vtx:LabWorkflowEntity ;
    rdfs:label "Well Volume" ;
    vtx:quantifies vtx:well ;
    rdfs:comment "AFO:AFR_0002232 — Quantifies material volume per well" .

obo:OBI_0302716 a vtx:LabWorkflowEntity ;
    rdfs:label "Pool of Specimens" ;
    rdfs:comment """OBI:0302716 — Mixture of population samples
Gathered from one or more sample populations""" ;
    rdfs:subClassOf obo:OBI_0100051 .

