        bao:BAO_0000427,
        bao:BAO_0000452,
        bao:BAO_0000657,
        bao:BAO_0010264,
        bao:BAO_0050013 .

bao:BAO_0000040 a vtx:LabWorkflowEntity ;
    rdfs:label "Measure Group" ;
    rdfs:comment """BAO:0000040 — Groups multiple result sets
Supports multiplexed/panel assays""" .

bao:BAO_0000057 a vtx:DetectionMethod ;
    rdfs:label "SPR (Surface Plasmon Resonance)" ;
    vtx:measures_KD obo:NCIT_C138151,
        vtx:cftr,
