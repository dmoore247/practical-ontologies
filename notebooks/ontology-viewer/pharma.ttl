bao:BAO_0002169 a vtx:ReadoutContent ;
    rdfs:label "Assay Readout Content" ;
    vtx:governed_by bao:BAO_0000409,
        bao:BAO_0000532,
        bao:BAO_0002067 ;
    vtx:governs vtx:applicability ;
    vtx:hasType bao:BAO_0000184,
        bao:BAO_0000534,
        bao:BAO_0000564 ;
    vtx:specifies bao:BAO_0002969 ;
